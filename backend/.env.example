APP_NAME=Deepthi Hospitals Management Platform
ENVIRONMENT=development
DEBUG=True

HOST=0.0.0.0
PORT=8000

POSTGRES_USER=postgres
POSTGRES_PASSWORD=YOUR_PGPASSWORD
POSTGRES_DB=deepthi_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PGPASSWORD@localhost:5432/deepthi_db

SECRET_KEY=replace-this-with-a-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080

LOG_LEVEL=INFO

# Razorpay — get from https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_REPLACE_ME
RAZORPAY_KEY_SECRET=REPLACE_ME

# CORS — comma separated, add your frontend URL
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
