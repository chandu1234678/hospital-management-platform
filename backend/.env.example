# =========================
# APP CONFIGURATION
# =========================
APP_NAME=Hospital Management Platform
ENVIRONMENT=development
DEBUG=True

# =========================
# SERVER
# =========================
HOST=0.0.0.0
PORT=8000

# =========================
# DATABASE (PostgreSQL)
# =========================
POSTGRES_USER=hospital
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=hospital_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://hospital:your_secure_password@localhost:5432/hospital_db

# =========================
# JWT AUTHENTICATION
# =========================
SECRET_KEY=change_this_to_a_long_random_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# =========================
# REDIS (Optional Future)
# =========================
REDIS_HOST=localhost
REDIS_PORT=6379

# =========================
# LOGGING
# =========================
LOG_LEVEL=INFO